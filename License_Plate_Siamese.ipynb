   "source": [
    "# Save plots + append experiment results to CSV log\n",
    "import pandas as pd\n",
    "from sklearn.metrics import roc_curve\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Save ROC plot\n",
    "fpr, tpr, _ = roc_curve(y_true, y_score)\n",
    "roc_path = os.path.join(DRIVE_PLOTS_DIR, f\"{EXP_ID}_roc.png\")\n",
    "\n",
    "plt.figure()\n",
    "plt.plot(fpr, tpr, label=f\"AUC={best_auc:.3f}\")\n",
    "plt.xlabel(\"False Positive Rate\")\n",
    "plt.ylabel(\"True Positive Rate\")\n",
    "plt.title(f\"ROC - {EXP_ID}\")\n",
    "plt.legend()\n",
    "plt.savefig(roc_path)\n",
    "plt.close()\n",
    "\n",
    "# Save loss plot\n",
    "loss_path = os.path.join(DRIVE_PLOTS_DIR, f\"{EXP_ID}_loss.png\")\n",
    "plt.figure()\n",
    "plt.plot(train_losses)\n",
    "plt.xlabel(\"Epoch\")\n",
    "plt.ylabel(\"Loss\")\n",
    "plt.title(f\"Training Loss - {EXP_ID}\")\n",
    "plt.savefig(loss_path)\n",
    "plt.close()\n",
    "\n",
    "# Append to CSV log\n",
    "row = {\n",
    "    \"Experiment_ID\": EXP_ID,\n",
    "    \"Dataset\": \"Kaggle_ALPR_201\",\n",
    "    \"Num_Images\": 201,\n",
    "    \"Epochs\": EPOCHS,\n",
    "    \"Batch_Size\": train_loader.batch_size,\n",
    "    \"Learning_Rate\": optimizer.param_groups[0][\"lr\"],\n",
    "    \"Margin\": getattr(criterion, \"margin\", None),\n",
    "    \"Best_Validation_AUC\": best_auc,\n",
    "    \"Training_Time_Minutes\": total_time,\n",
    "    \"Model_Path\": best_path,\n",
    "    \"ROC_Plot\": roc_path,\n",
    "    \"Loss_Plot\": loss_path,\n",
    "    \"Notes\": \"Baseline Siamese on small Kaggle dataset (pseudo grouping)\"\n",
    "}\n",
    "\n",
    "df_new = pd.DataFrame([row])\n",
    "\n",
    "if os.path.exists(DRIVE_LOG_PATH):\n",
    "    df_old = pd.read_csv(LOGS_PATH)\n",
    "    df_all = pd.concat([df_old, df_new], ignore_index=True)\n",
    "else:\n",
    "    df_all = df_new\n",
    "\n",
    "df_all.to_csv(DRIVE_LOG_PATH, index=False)\n",
    "\n",
    "print(\"Saved ROC:\", roc_path)\n",
    "print(\"Saved loss plot:\", loss_path)\n",
    "print(\"Updated log:\", DRIVE_LOG_PATH)"
   ]
