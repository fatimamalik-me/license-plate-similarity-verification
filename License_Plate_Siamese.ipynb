   "source": [
    "def evaluate(model, loader):\n",
    "    model.eval()\n",
    "    all_labels, all_scores = [], []\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for x1, x2, y in loader:\n",
    "            x1, x2, y = x1.to(device), x2.to(device), y.to(device)\n",
    "            e1, e2 = model(x1, x2)\n",
    "            dist = F.pairwise_distance(e1, e2)\n",
    "\n",
    "            # Convert distance to similarity score (higher = more similar)\n",
    "            score = (-dist).detach().cpu().numpy()\n",
    "            all_scores.extend(score.tolist())\n",
    "            all_labels.extend(y.detach().cpu().numpy().tolist())\n",
    "\n",
    "    auc = roc_auc_score(all_labels, all_scores)\n",
    "    return auc, np.array(all_labels), np.array(all_scores)\n",
    "\n",
    "def train_one_epoch(model, loader):\n",
    "    model.train()\n",
    "    running_loss = 0.0\n",
    "\n",
    "    for x1, x2, y in tqdm(loader, desc=\"Training\", leave=False):\n",
    "        x1, x2, y = x1.to(device), x2.to(device), y.to(device)\n",
    "\n",
    "        optimizer.zero_grad()\n",
    "        e1, e2 = model(x1, x2)\n",
    "        loss, _ = criterion(e1, e2, y)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "\n",
    "        running_loss += loss.item()\n",
    "\n",
    "    return running_loss / len(loader)\n",
    "# Training + best model saving\n",
    "EPOCHS = 10\n",
    "start_time = time.time()\n",
    "\n",
    "best_auc = -1\n",
    "best_path = os.path.join(DRIVE_MODELS_DIR, f\"{EXP_ID}_best_model.pth\")\n",
    "\n",
    "train_losses, val_aucs = [], []\n",
    "\n",
    "for epoch in range(1, EPOCHS + 1):\n",
    "    loss = train_one_epoch(model, train_loader)\n",
    "    auc, y_true, y_score = evaluate(model, val_loader)\n",
    "\n",
    "    train_losses.append(loss)\n",
    "    val_aucs.append(auc)\n",
    "\n",
    "    print(f\"Epoch {epoch}/{EPOCHS} | Train Loss: {loss:.4f} | Val ROC-AUC: {auc:.4f}\")\n",
    "\n",
    "    if auc > best_auc:\n",
    "        best_auc = auc\n",
    "        torch.save(model.state_dict(), best_path)\n",
    "\n",
    "total_time = round((time.time() - start_time) / 60, 2)\n",
    "\n",
    "print(\"\\nBest Val ROC-AUC:\", best_auc)\n",
    "print(\"Saved best model to:\", best_path)\n",
    "print(\"Training time (minutes):\", total_time)"
   ]
  },
