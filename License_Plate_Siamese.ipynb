   "source": [
    "# Clean TRAIN_ROOT as it already has old content\n",
    "for name in os.listdir(TRAIN_ROOT):\n",
    "    p = os.path.join(TRAIN_ROOT, name)\n",
    "    if os.path.isdir(p):\n",
    "        shutil.rmtree(p)\n",
    "\n",
    "imgs = sorted(\n",
    "    glob.glob(os.path.join(IMG_DIR, \"*.jpg\")) +\n",
    "    glob.glob(os.path.join(IMG_DIR, \"*.png\")) +\n",
    "    glob.glob(os.path.join(IMG_DIR, \"*.jpeg\"))\n",
    ")\n",
    "\n",
    "print(\"Flat images found:\", len(imgs))\n",
    "\n",
    "# Make 2 images per pseudo-class folder\n",
    "for i, img in enumerate(imgs):\n",
    "    plate_dir = os.path.join(TRAIN_ROOT, f\"plate_{i//2:04d}\")\n",
    "    os.makedirs(plate_dir, exist_ok=True)\n",
    "    shutil.copy(img, os.path.join(plate_dir, os.path.basename(img)))\n",
    "\n",
    "plate_folders = [d for d in os.listdir(TRAIN_ROOT) if os.path.isdir(os.path.join(TRAIN_ROOT, d))]\n",
    "print(\"Created plate folders:\", len(plate_folders))\n",
    "print(\"Example folder contents:\", plate_folders[:5], \"->\", os.listdir(os.path.join(TRAIN_ROOT, plate_folders[0]))[:3])\n"
   ]
